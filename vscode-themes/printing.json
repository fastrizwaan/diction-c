{
    "name": "printing",
    "type": "light",
    "colors": {
        "editor.lineHighlightBackground": "#f6f6f6",
        "editorLineNumber.foreground": "#d0d0d0",
        "editor.background": "#ffffff",
        "editor.foreground": "#303030"
    },
    "tokenColors": [
        {
            "scope": [
                "comment"
            ],
            "settings": {
                "foreground": "#909090"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "comment"
            ],
            "settings": {
                "foreground": "#707070"
            }
        },
        {
            "scope": [
                "comment"
            ],
            "settings": {
                "foreground": "#404040"
            }
        },
        {
            "scope": [
                "constant.numeric"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "keyword"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.control.directive"
            ],
            "settings": {
                "foreground": "#707070"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation"
            ],
            "settings": {
                "foreground": "#101010",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "constant"
            ],
            "settings": {
                "foreground": "#000000"
            }
        },
        {
            "scope": [
                "string"
            ],
            "settings": {
                "foreground": "#707070"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "support.type"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        }
    ]
}